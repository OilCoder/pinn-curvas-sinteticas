{
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/statusline.sh\""
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(printf *)",
      "Bash(mkdir -p *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(python -m *)",
      "Bash(pip *)",
      "Bash(jupyter *)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-context.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-suggest-checkpoint.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(rm -rf *)",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'BLOCKED: rm -rf is restricted. Delete specific files instead, or ask the user for explicit approval.' >&2; exit 2"
          }
        ]
      },
      {
        "matcher": "Bash(git push --force *)",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'BLOCKED: force-push requires explicit user approval.' >&2; exit 2"
          }
        ]
      },
      {
        "matcher": "Bash(git push -f *)",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'BLOCKED: force-push requires explicit user approval.' >&2; exit 2"
          }
        ]
      },
      {
        "matcher": "Bash(git reset --hard *)",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'BLOCKED: git reset --hard discards uncommitted work. Ask the user before proceeding.' >&2; exit 2"
          }
        ]
      },
      {
        "matcher": "Bash(git commit *--no-verify*)",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'BLOCKED: --no-verify skips pre-commit hooks. Fix the underlying issue instead.' >&2; exit 2"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-debug-isolation.sh\""
          },
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; [[ \"$f\" == *.py ]] && cd \"$CLAUDE_PROJECT_DIR\" && ruff format \"$f\" && ruff check --fix \"$f\" || true'"
          }
        ]
      }
    ]
  }
}
