flowchart TD
    A["Raw LAS<br/>Kraft Prusa"] --> B["data_loader.py<br/>load_well"]
    B --> C["Mnemonic mapping<br/>GR, RT, RILM, NPHI, SP, DEN, DCAL"]
    C --> D["Acquisition fixes<br/>NPHI % → v/v<br/>RT>1e6 sentinels → NaN<br/>LAS -9999 sentinels → NaN"]
    D --> E["dropna canonical curves<br/>≥100 rows required"]
    E --> F["Raw DataFrame<br/>correct physical units"]
    F --> G["preprocess_well<br/>src/preprocessing.py"]
    G --> G1["Step 1: DCAL washout<br/>DCAL > Q75+1.5×IQR → NaN features+DEN"]
    G1 --> G2["Step 2: Voting consensus outliers<br/>≥2 of 5 detectors → NaN → linear interpolation"]
    G2 --> G3["Step 3: Drop invalid DEN<br/>DEN < 1.5 or DEN > 3.1 g/cc → drop row"]
    G3 --> G4["Step 4: DCAL_WEIGHT<br/>caliper quality in original units"]
    G4 --> G5["Step 5: log₁₀ RT and RILM<br/>log-normal distribution"]
    G5 --> G6["Step 6: Per-well normalization<br/>GR/SP/DEN: Yeo-Johnson+zscore<br/>RT/RILM/NPHI: StandardScaler"]
    G6 --> G7["DCAL_WEIGHT attached<br/>non-normalized column"]
    G7 --> H["Normalized DataFrame<br/>≈ N 0,1 per column"]
    H --> I["WellDataset<br/>PyTorch tensors"]
    I --> J["This is the data that<br/>trains the model<br/>LOWO · 27 folds"]
